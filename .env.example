# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai-video-processor
KAFKA_TOPIC_REQUEST=video-ai-analysis-requested
KAFKA_TOPIC_RESULT=video-ai-analysis-completed

# ── AWS S3 ──
S3_BUCKET_NAME=asn-s3-bucket
AWS_DEFAULT_REGION=ap-northeast-2

# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── PostgreSQL (PGVector) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ── Whisper STT ──
WHISPER_MODEL_SIZE=medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ko

# ── Server ──
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
